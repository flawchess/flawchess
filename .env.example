# FlawChess environment configuration
# Copy to .env and fill in values

# Environment: "development" enables CORS for localhost:5173 and bypasses JWT auth
# Environment: "production" disables CORS (same-origin via Caddy)
ENVIRONMENT=development

# PostgreSQL
# Production (docker-compose.yml): uses POSTGRES_USER/PASSWORD/DB for the db container
# Development (docker-compose.dev.yml): uses postgres:postgres superuser, creates flawchess user via init script
POSTGRES_USER=flawchess
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=flawchess
DATABASE_URL=postgresql+asyncpg://flawchess:flawchess@localhost:5432/flawchess
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flawchess_test
DB_ECHO=false

# Application secret (generate with: openssl rand -hex 32)
SECRET_KEY=

# URLs (production: both point to https://flawchess.com)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Google OAuth (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Sentry error monitoring (from sentry.io project settings -> Client Keys)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Umami analytics (self-hosted at analytics.flawchess.com)
UMAMI_DB_USER=umami
# Generate with: openssl rand -hex 16
UMAMI_DB_PASSWORD=
# Generate with: openssl rand -hex 32
UMAMI_APP_SECRET=
