# FlawChess environment configuration
# Copy to .env and fill in values

# Environment: "development" enables CORS for localhost:5173 and bypasses JWT auth
# Environment: "production" disables CORS (same-origin via Caddy)
ENVIRONMENT=development

# PostgreSQL
# Production (docker-compose.yml): uses POSTGRES_USER/PASSWORD/DB for the db container
# Development (docker-compose.dev.yml): uses postgres:postgres superuser, creates flawchess user via init script
POSTGRES_USER=flawchess
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=flawchess
# DATABASE_URL is what the running app + Alembic connect to (dev = same as
# DATABASE_URL_DEV). The DATABASE_URL_* variants below are the single source of
# truth for the maintenance scripts that take a --db dev|benchmark|prod flag
# (backfill_eval, reindex_table, gen_benchmarks, …), resolved via
# app.core.config.db_url_for_target. All are reached over localhost:
# dev/benchmark via Docker, prod via the SSH tunnel from bin/prod_db_tunnel.sh.
DATABASE_URL=postgresql+asyncpg://flawchess:flawchess@localhost:5432/flawchess
DATABASE_URL_DEV=postgresql+asyncpg://flawchess:flawchess@localhost:5432/flawchess
# DATABASE_URL_TEST: tests read host/port/user/password from this URL (the user
# must be able to CREATE DATABASE). The database-name part is only a placeholder
# — each run/worker clones its own flawchess_test_<pid|worker> DB at runtime
# (tests/conftest.py); no static "flawchess_test" database is created or used.
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/flawchess_test
# DATABASE_URL_PROD: prod app-user credentials over the tunnel (localhost:15432).
# The password is the prod app user's, not the dev one.
DATABASE_URL_PROD=postgresql+asyncpg://flawchess:<prod-password>@localhost:15432/flawchess
DATABASE_URL_BENCHMARK=postgresql+asyncpg://flawchess_benchmark:flawchess_benchmark@localhost:5433/flawchess_benchmark
DB_ECHO=false

# Application secret (generate with: openssl rand -hex 32)
SECRET_KEY=

# URLs (production: both point to https://flawchess.com)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Google OAuth (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Sentry error monitoring (from sentry.io project settings -> Client Keys)
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Umami analytics (self-hosted at analytics.flawchess.com)
UMAMI_DB_USER=umami
# Generate with: openssl rand -hex 16
UMAMI_DB_PASSWORD=
# Generate with: openssl rand -hex 32
UMAMI_APP_SECRET=

# Supports any pydantic-ai model string; requires matching provider API key set.
# Tests use the built-in "test" provider (set in tests/conftest.py) — no real
# API key needed to run the test suite.
PYDANTIC_AI_MODEL_INSIGHTS=google:gemini-3.5-flash
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Gemini thinking controls (ignored for non-Google providers).
# THINKING_LEVEL: Gemini 3+ knob — "minimal" | "low" | "medium" | "high"
#   (increasing reasoning/cost/latency; "minimal" is cheapest/fastest).
# THINKING_BUDGET: Gemini 2.5 knob — explicit token cap; 0 disables thinking.
# INCLUDE_THOUGHTS: when true, persists thinking token counts to llm_logs for cost attribution.
GEMINI_THINKING_LEVEL=low
GEMINI_THINKING_BUDGET=0
GEMINI_INCLUDE_THOUGHTS=true
# Set to true to strip report.overview from the API response (full overview is
# still captured in llm_logs.response_json for offline analysis).
INSIGHTS_HIDE_OVERVIEW=false

# Stockfish engine pool size for the long-lived module-level engine used by
# import-time eval. 1 = legacy single-process behaviour (fine for dev/CI).
# Prod docker-compose.yml defaults this to 2 so the import eval pass fans out
# across two cores. Increase with care — each process holds 64 MB hash and
# competes with Postgres for CPU.
STOCKFISH_POOL_SIZE=1

# Automatic background full-eval toggle (the "tier-3 idle drain"). Controls
# whether idle Stockfish workers self-feed from the backlog of un-analyzed
# games when there is no explicit, on-demand work to do.
#   true  = prod behaviour. Idle workers pull games off the backlog and eval
#           them in the background until the backlog is drained.
#   false = suppress the idle drain entirely. Use this in dev/CI so a local
#           backend does not pin every core grinding the backlog.
# This gates ONLY the automatic tier-3 idle pick. Tier-1 explicit, on-demand
# single-game eval requests (the "Analyze" button) are NEVER gated, so
# on-demand analysis keeps working even when this is false. (Tier-2 auto-window
# enqueue was removed in Phase 118, so tier-3 is the sole automatic source.)
# Code default is false (safe for dev/CI); the prod compose opts in to true.
EVAL_AUTO_DRAIN_ENABLED=false

# Operator token for the remote eval worker (scripts/remote_eval_worker.py,
# Phase 120). Empty = the /api/eval/remote/* lease + submit endpoints return 403
# (disabled in dev/CI). Prod sets a strong random secret (generate with:
# openssl rand -hex 32). The off-box worker reads the same value from its own
# .env (or --token for a one-off run). See the "Remote eval
# worker" section in README.md.
EVAL_OPERATOR_TOKEN=

# Expected Stockfish version for the remote eval submit version gate (D-5),
# e.g. "Stockfish 18". Empty = accept any version (dev/CI). Prod sets this to the
# engine build installed on the server so submissions from a mismatched worker
# build are rejected with 422.
EXPECTED_SF_VERSION="Stockfish 18"
