flawchess.org, www.flawchess.org {
    redir https://flawchess.com{uri} permanent
}

analytics.flawchess.com {
    reverse_proxy umami:3000
}

flawchess.com {
    encode gzip

    # Frontend SPA — serve static files first
    # If the file exists on disk (JS, CSS, images, etc.), serve it directly
    @static file
    handle @static {
        root * /srv

        # Service worker and PWA manifest must never be HTTP-cached so browsers
        # detect new deployments immediately on every page load (SW spec requires
        # revalidation, but no-cache enforces it on every request, not just every 24h).
        @nocache path /sw.js /registerSW.js /manifest.webmanifest
        header @nocache Cache-Control "no-cache"

        # Content-hashed assets (Vite output: /assets/index-Bb5kahVl.js etc.) are
        # safe to cache forever — any content change produces a new filename.
        @immutable path /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"

        file_server
    }

    # Backend API — single rule, all backend routes are under /api/
    handle /api/* {
        reverse_proxy backend:8000
    }

    # SPA fallback — all remaining paths get index.html
    handle {
        root * /srv
        header /index.html Cache-Control "no-cache"
        try_files /index.html
        file_server
    }
}
