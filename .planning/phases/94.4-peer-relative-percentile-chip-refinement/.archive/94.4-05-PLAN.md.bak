Lichess-precedence (CONTEXT D-12, RESEARCH Pitfall 5):
  async def compute_anchors_for_user(session, user_id) -> dict[TimeControlBucket, RatingAnchorRow]:
      # For each TC:
      # 1. Query: does this user have ANY Lichess games in TC?
      # 2. If yes: source_platform = 'lichess', call per_user_cte_median_anchor(tc, source='single_user', platform='lichess')
      # 3. If no: source_platform = 'chesscom', call per_user_cte_median_anchor(tc, source='single_user', platform='chesscom'),
      #    then convert chess.com rating to Lichess-equivalent via convert_chesscom_to_lichess
      # 4. Upsert via upsert_anchor (Plan 02)
      # 5. Returns dict for the percentile compute loop

Aggregation helper (PATTERNS lines 510-532, CONTEXT D-08 / D-08b):
  def _aggregate_per_tc_percentile(
      per_tc_rows: Mapping[TimeControlBucket, PercentileRow] | None,
  ) -> float | None:
      """Game-count-weighted mean per CONTEXT D-08."""
      if per_tc_rows is None or not per_tc_rows:
          return None
      weighted_sum = 0.0
      weight_sum = 0
      for tc_row in per_tc_rows.values():
          if tc_row.percentile is None: continue
          weighted_sum += tc_row.percentile * tc_row.n_games
          weight_sum += tc_row.n_games
      if weight_sum == 0: return None
      return weighted_sum / weight_sum

Schema extension (PATTERNS lines 546-554, RESEARCH Open Question 4):
